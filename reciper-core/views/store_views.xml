<odoo>
    <record id="action_stores" model="ir.actions.act_window">
        <field name="name">Stores</field>
        <field name="res_model">store</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="store_list" model="ir.ui.view">
        <field name="name">store.list</field>
        <field name="model">store</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="store_form" model="ir.ui.view">
        <field name="name">store.form</field>
        <field name="model">store</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="aisle_ids">
                            <list>
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
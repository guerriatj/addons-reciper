<odoo>
    <record id="action_ingredients" model="ir.actions.act_window">
        <field name="name">Ingredients</field>
        <field name="res_model">recipe.ingredient</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="recipe_ingredient_list" model="ir.ui.view">
        <field name="name">recipe.ingredient.list</field>
        <field name="model">recipe.ingredient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="uom_id"/>
            </list>
        </field>
    </record>

    <record id="recipe_ingredient_form" model="ir.ui.view">
        <field name="name">recipe.ingredient.form</field>
        <field name="model">recipe.ingredient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="uom_id"/>
                        <field name="aisle_ids">
                            <list>
                                <field name="name"/>
                                <field name="store_id"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="recipe_ingredient_search" model="ir.ui.view">
        <field name="name">recipe.ingredient.search</field>
        <field name="model">recipe.ingredient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter
                    name="group_uom"
                    string="Group by UoM"
                    context="{'group_by':'uom_id'}"
                />
            </search>
        </field>
    </record>
</odoo>

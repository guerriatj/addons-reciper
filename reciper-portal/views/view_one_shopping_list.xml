<odoo>
    <template id="create_shopping_list_template" name="View Shopping List Page">
        <t t-call="website.layout">
            <h1><t t-esc="shopping_list.display_name"/></h1>

            <form class="shopping-list-form" method="POST" action="/my/shopping/list/new">
                <input type="hidden" name="shopping_list_id" t-att-value="shopping_list.id"/>

                <!-- Sélecteur de recettes -->
                <div class="form-group">
                    <label for="recipe_ids">Select Recipes</label>
                    <select name="recipe_ids" id="recipe_ids" multiple="multiple" class="form-control">
                        <t t-foreach="recipes" t-as="recipe">
                            <option t-att-value="recipe.id"><t t-esc="recipe.name"/></option>
                        </t>
                    </select>
                </div>

                <!-- Sélecteur d'ingrédients -->
                <div class="form-group">
                    <label for="ingredient_ids">Select Ingredients</label>
                    <input type="text" id="ingredient_filter" placeholder="Filter by name" class="form-control mb8"/>
                    <select name="ingredient_ids" id="ingredient_ids" multiple="multiple" class="form-control">
                        <t t-foreach="ingredients" t-as="ingredient">
                            <option t-att-value="ingredient.id"><t t-esc="ingredient.name"/></option>
                        </t>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary mt8">Save Shopping List</button>
            </form>
        </t>
    </template>
</odoo>

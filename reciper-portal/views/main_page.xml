<odoo>
    <template id="shopping_page_template" name="Shopping Page">
        <t t-call="portal.portal_layout">
            <div class="container py-3">
                <h1>Shopping Dashboard</h1>
                <div class="d-flex flex-column flex-md-row gap-2 mt-3">
                    <a href="/my/shopping/list"
                       class="btn btn-primary flex-fill mb-2 mb-md-0 text-center">
                        View Shopping List
                    </a>
                    <a href="/my/shopping/list/new"
                       class="btn btn-success flex-fill mb-2 mb-md-0 text-center">
                        Create New Shopping List
                    </a>
                    <a href="/my/shopping/recipe/new"
                       class="btn btn-warning flex-fill mb-2 mb-md-0 text-center">
                        Create Recipe
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>
<odoo>
    <record id="action_set_aisle_wizard" model="ir.actions.act_window">
        <field name="name">Set Aisle</field>
        <field name="res_model">set.aisle.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
    id="menu_set_aisle_wizard"
    name="Set Ingredient Aisles"
    parent="reciper-core.recipe_root_menu"
    action="action_set_aisle_wizard"
/>

    <record id="view_set_aisle_wizard_form" model="ir.ui.view">
        <field name="name">set.aisle.wizard.form</field>
        <field name="model">set.aisle.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="store_id"/>
                    <field name="aisle_id"
                           domain="[('store_id', '=', store_id)]"
                           options="{'no_create': True}"/>
                    <field name="ingredient_to_set_ids" domain="ingredient_domain" invisible="not store_id or not aisle_id"/>
                </group>
                <footer>
                    <button string="Apply"
                            type="object"
                            name="action_apply"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
<odoo>
    <record id="action_shopping_lists" model="ir.actions.act_window">
        <field name="name">Shopping List</field>
        <field name="res_model">shopping.list</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="shopping_list_list" model="ir.ui.view">
        <field name="name">shopping.list.list</field>
        <field name="model">shopping.list</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name"/>
            </list>
        </field>
    </record>

    <record id="shopping_list_form" model="ir.ui.view">
        <field name="name">shopping.list.form</field>
        <field name="model">shopping.list</field>
        <field name="arch" type="xml">
            <form>
                <header>
                        <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            invisible="state != 'draft'"
                            class="btn-primary"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,completed"/>
                    </header>
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="store_id"/>
                    </group>
                    <group>
                        <field name="shopping_list_recipe_line_ids">
                            <list editable="top">
                                <field name="recipe_id"/>
                                <field name="people_count"/>
                            </list>
                        </field>
                        <field name="shopping_list_ingredient_line_ids">
                            <list editable="top">
                                <field name="ingredient_count"/>
                                <field name="ingredient_id"/>
                                <field name="uom_id"/>
                            </list>
                        </field>
                    </group>
                    <field name="shopping_list_line_ids">
                        <list editable="bottom">
                            <field name="recipe_ingredient_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="recipe_ids" widget="many2many_tags"/>
                            <field name="aisle_id"/>
                            <field name="is_picked"/>
                            <button name="set_picked" type="object" string="Set Picked"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

</odoo>